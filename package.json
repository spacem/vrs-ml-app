{
  "name": "vrs-ml-app",
  "version": "1.0.20",
  "description": "VRS-ML Desktop Application",
  "main": "dist/main.js",
  "author": "spacem",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsc && cross-env NODE_ENV=development electron .",
    "build": "tsc",
    "start": "tsc && cross-env NODE_ENV=development electron . --enable-logging",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "cross-env": "^10.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-reloader": "^1.2.3",
    "electron-types": "^40.6.0",
    "typescript": "^5.7.2"
  }
}
